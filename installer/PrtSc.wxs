<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="PrtSc"
      Language="1033"
      Version="$(var.ProductVersion)"
      Manufacturer="PrtSc"
      UpgradeCode="5AE96A1D-4644-40D2-90FA-E6E4EED7D147">

    <Package
        InstallerVersion="500"
        Compressed="yes"
        InstallScope="perUser"
        InstallPrivileges="limited"
        Platform="x64"
        Description="PrtSc screenshot tool" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of PrtSc is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="ARPPRODUCTICON" Value="PrtScIcon" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch PrtSc" />

    <CustomAction
        Id="LaunchPrtSc"
        FileKey="PrtScExe"
        ExeCommand=""
        Execute="immediate"
        Impersonate="yes"
        Return="asyncNoWait" />

    <Icon Id="PrtScIcon" SourceFile="$(var.ProjectDir)\assets\app-icon\PrtSc.ico" />
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="LocalProgramsFolder" Name="Programs">
          <Directory Id="INSTALLFOLDER" Name="PrtSc">
            <Component Id="PrtScExeComponent" Guid="B89310D0-9015-48AF-86F6-5AB8B1E292DA" Win64="yes">
              <File Id="PrtScExe" Source="$(var.SourceDir)\PrtSc.exe" />
              <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
              <RemoveFolder Id="RemoveLocalProgramsFolder" Directory="LocalProgramsFolder" On="uninstall" />
              <RegistryValue
                  Root="HKCU"
                  Key="Software\PrtSc"
                  Name="InstalledExe"
                  Type="integer"
                  Value="1"
                  KeyPath="yes" />
            </Component>

            <Component Id="PrtScOcrComponent" Guid="6476C692-B58E-429E-ACD7-BB21BE62097C" Win64="yes">
              <File Id="PrtScOcrDll" Source="$(var.SourceDir)\PrtScOcr.dll" />
              <RegistryValue
                  Root="HKCU"
                  Key="Software\PrtSc"
                  Name="InstalledOcr"
                  Type="integer"
                  Value="1"
                  KeyPath="yes" />
            </Component>

            <Component Id="StartupComponent" Guid="F2D6E237-E79F-43B1-ABE9-FC4B27BAC938" Win64="yes">
              <RegistryValue
                  Root="HKCU"
                  Key="Software\Microsoft\Windows\CurrentVersion\Run"
                  Name="PrtSc"
                  Type="string"
                  Value="&quot;[INSTALLFOLDER]PrtSc.exe&quot;"
                  KeyPath="yes" />
            </Component>
          </Directory>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="PrtSc">
          <Component Id="StartMenuShortcutComponent" Guid="CF0C2E11-C9DA-4B76-94B2-9D15F7FEB568" Win64="yes">
            <Shortcut
                Id="ApplicationStartMenuShortcut"
                Name="PrtSc"
                Description="Launch PrtSc"
                Target="[INSTALLFOLDER]PrtSc.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="PrtScIcon" />
            <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
            <RegistryValue
                Root="HKCU"
                Key="Software\PrtSc"
                Name="StartMenuShortcut"
                Type="integer"
                Value="1"
                KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="PrtSc" Level="1">
      <ComponentRef Id="PrtScExeComponent" />
      <ComponentRef Id="PrtScOcrComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>

    <Feature Id="StartupFeature" Title="Run PrtSc at startup" Level="2">
      <ComponentRef Id="StartupComponent" />
    </Feature>

    <UIRef Id="PrtScUI_InstallDir" />

    <SetProperty
        Id="ADDLOCAL"
        Value="MainFeature,StartupFeature"
        Before="CostFinalize"
        Sequence="both">PRTSC_STARTUP = "1"</SetProperty>

    <InstallExecuteSequence>
      <Custom Action="LaunchPrtSc" After="InstallFinalize">LAUNCH_PRTSC = "1"</Custom>
    </InstallExecuteSequence>
  </Product>

  <Fragment>
    <UI Id="PrtScUI_InstallDir">
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />

      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
      <Property Id="WixUI_Mode" Value="InstallDir" />

      <DialogRef Id="BrowseDlg" />
      <DialogRef Id="DiskCostDlg" />
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />

      <Dialog Id="StartupOptionsDlg" Width="370" Height="270" Title="[ProductName] Setup">
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="Title" Type="Text" X="15" Y="6" Width="300" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Startup Options" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="320" Height="15" Transparent="yes" NoPrefix="yes" Text="Choose how PrtSc starts." />
        <Control Id="TopLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <Control Id="BodyText" Type="Text" X="20" Y="70" Width="330" Height="30" Text="PrtSc can launch automatically when Windows starts." />
        <Control Id="StartupCheckBox" Type="CheckBox" X="20" Y="110" Width="330" Height="17" Property="PRTSC_STARTUP" CheckBoxValue="1" Text="Run PrtSc at startup" />

        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)">
          <Publish Event="SpawnDialog" Value="CancelDlg">1</Publish>
        </Control>
      </Dialog>

      <Publish Dialog="BrowseDlg" Control="OK" Event="DoAction" Value="WixUIValidatePath" Order="3">1</Publish>
      <Publish Dialog="BrowseDlg" Control="OK" Event="SpawnDialog" Value="InvalidDirDlg" Order="4"><![CDATA[NOT WIXUI_DONTVALIDATEPATH AND WIXUI_INSTALLDIR_VALID<>"1"]]></Publish>

      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchPrtSc" Order="1">WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1</Publish>
      <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999">1</Publish>

      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg">NOT Installed</Publish>
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg">Installed AND PATCH</Publish>

      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="SetTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="DoAction" Value="WixUIValidatePath" Order="2">NOT WIXUI_DONTVALIDATEPATH</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="SpawnDialog" Value="InvalidDirDlg" Order="3"><![CDATA[NOT WIXUI_DONTVALIDATEPATH AND WIXUI_INSTALLDIR_VALID<>"1"]]></Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="StartupOptionsDlg" Order="4">WIXUI_DONTVALIDATEPATH OR WIXUI_INSTALLDIR_VALID="1"</Publish>
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Property="_BrowseProperty" Value="[WIXUI_INSTALLDIR]" Order="1">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Event="SpawnDialog" Value="BrowseDlg" Order="2">1</Publish>

      <Publish Dialog="StartupOptionsDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg">1</Publish>
      <Publish Dialog="StartupOptionsDlg" Control="Next" Event="AddLocal" Value="StartupFeature" Order="1">PRTSC_STARTUP = "1"</Publish>
      <Publish Dialog="StartupOptionsDlg" Control="Next" Event="Remove" Value="StartupFeature" Order="2">PRTSC_STARTUP &lt;&gt; "1"</Publish>
      <Publish Dialog="StartupOptionsDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg">1</Publish>

      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="StartupOptionsDlg" Order="1">NOT Installed</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2">Installed AND NOT PATCH</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2">Installed AND PATCH</Publish>

      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg">1</Publish>

      <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
      <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
      <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg">1</Publish>

      <Property Id="ARPNOMODIFY" Value="1" />
    </UI>

    <UIRef Id="WixUI_Common" />
  </Fragment>
</Wix>
